# Copy to .env at repo root (optional) or export before docker compose:
#   docker compose --env-file deploy/.env -f deploy/docker-compose.yml up

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Npgsql — same key as appsettings.json (double underscore for nested config in Docker/K8s)
ConnectionStrings__PostgreSql=Host=postgres;Port=5432;Database=high_performance_ingest;Username=postgres;Password=postgres

# Leaderboard aggregation window (days)
LeaderboardSettings__WindowDays=7

# Max rows per POST /api/scores/bulk
LeaderboardSettings__MaxScoreBatchSize=10000
